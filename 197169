    </div>

    <h2>You might like</h2>

    <div class="upsell" data-price="99.99">
      <div class="upsell-left">
        <img src="data:image/svg+xml;base64," />
        <div>
          <div class="upsell-name">16,400 SkyBlock Gems</div>
